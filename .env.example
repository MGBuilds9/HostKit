# Database
DATABASE_URL=postgresql://hostkit:changeme@localhost:5432/hostkit

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Calendar Sync Cron
CRON_SECRET=generate-a-random-secret

# Resend (email notifications — optional, email disabled if omitted)
RESEND_API_KEY=re_xxxx
RESEND_FROM_ADDRESS=HostKit <notifications@updates.mkguirguis.com>

# Minio / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=hostkit
S3_PUBLIC_URL=https://minio.mkgbuilds.com/hostkit

# Public app URLs (used in client-side code)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Push Notifications (optional — push disabled if omitted)
# Generate VAPID keys with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY is exposed to the browser (safe to be public)
# VAPID_PRIVATE_KEY must remain server-side only — never expose to the client
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@mkgbuilds.com

# Sentry (error monitoring)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
